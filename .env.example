# Service URLs
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_QDRANT_URL=http://localhost:6333
RAG_POSTGRES_DSN=postgresql+psycopg://rag:rag@localhost:5432/rag
RAG_LANGFUSE_HOST=http://localhost:3000

# Models
RAG_DEFAULT_CHAT_MODEL=anthropic/claude-sonnet-4.6
RAG_DEFAULT_EMBED_MODEL=bge-m3

# Behaviour
RAG_LOG_LEVEL=INFO
RAG_ENV=local

# Secrets
# OpenRouter is the cloud LLM provider. The server needs this key for /answer
# (without it /answer returns 503). With enable_multimodal=True it also wires
# LLMQueryClassifier, which replaces a regex that misses synonyms like "graph",
# "image", or "bottom panel of...". MMLongBench numbers: regex 17% vs LLM 72%
# hybrid dispatch (settings.py:66-69).
RAG_OPENROUTER_API_KEY=sk-or-v1-replace-me
# Reserved for future direct-Anthropic / Langfuse wiring (not consumed yet).
# RAG_ANTHROPIC_API_KEY=sk-ant-replace-me
# RAG_LANGFUSE_PUBLIC_KEY=pk-lf-replace-me
# RAG_LANGFUSE_SECRET_KEY=sk-lf-replace-me

# Observability SDK env vars (NOT in Settings — read directly by the SDKs).
# Leave unset to keep both SDKs in no-op mode.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=prismrag
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=local
# SENTRY_TRACES_SAMPLE_RATE=0.1
